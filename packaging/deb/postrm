#!/bin/sh
set -e

case "$1" in
  purge)
    # Remove config and logs on purge
    rm -rf /etc/ntripcaster /var/log/ntripcaster
    # Remove user if no longer needed
    if getent passwd ntripcaster >/dev/null 2>&1; then
      deluser --system ntripcaster 2>/dev/null || true
    fi
    ;;
  remove|upgrade|failed-upgrade|abort-install|abort-upgrade|disappear)
    if command -v systemctl >/dev/null 2>&1; then
      systemctl daemon-reload || true
    fi
    ;;
esac

exit 0
